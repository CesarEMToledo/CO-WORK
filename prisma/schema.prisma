// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// DATABASE_URL (definida en prisma.config.ts, ver ese archivo) debe ser la
// conexión Postgres de tu proyecto de Supabase (Project Settings -> Database
// -> Connection string). Usa el "Session pooler" (puerto 5432) o la conexión
// directa — el pooler en modo "Transaction" (puerto 6543) no es compatible
// con @prisma/adapter-pg.
datasource db {
  provider = "postgresql"
}

enum Role {
  client
  agent
  broker
  admin
}

enum AccessLevel {
  site
  global
}

enum UserStatus {
  active
  inactive
  away
}

enum PropertyType {
  office
  meeting_room
}

enum PropertyStatus {
  available
  maintenance
  inactive
}

enum RateType {
  hourly
  daily
  monthly
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
  completed
}

enum IssueCategory {
  maintenance
  cleaning
  internet
  other
}

enum IssueStatus {
  open
  in_progress
  resolved
}

enum VisitRequestType {
  visita
  reserva
}

enum VisitRequestStatus {
  pending
  contacted
  confirmed
  cancelled
}

model Site {
  id         String     @id @default(cuid())
  name       String
  code       String     @unique
  users      User[]
  properties Property[]
  createdAt  DateTime   @default(now())
}

model User {
  id           String       @id @default(cuid())
  // Id del usuario en Supabase Auth (auth.users.id). La contraseña y el login
  // con Google los maneja Supabase; aquí solo guardamos el perfil de la app.
  authId       String       @unique
  name         String
  email        String       @unique
  phone        String?
  // URL pública del archivo en el bucket "avatars" de Supabase Storage.
  avatarUrl    String?
  role         Role         @default(client)
  accessLevel  AccessLevel?
  status       UserStatus   @default(active)
  siteId       String
  site         Site         @relation(fields: [siteId], references: [id])
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reservations Reservation[]
  assignments  PropertyAssignment[]
  issueReports IssueReport[]

  @@index([role, siteId])
}

model Property {
  id          String         @id @default(cuid())
  siteId      String
  site        Site           @relation(fields: [siteId], references: [id])
  name        String
  type        PropertyType
  capacity    Int
  hourlyRate  Decimal        @db.Decimal(10, 2)
  dailyRate   Decimal        @db.Decimal(10, 2)
  monthlyRate Decimal        @db.Decimal(10, 2)
  status      PropertyStatus @default(available)
  createdAt   DateTime       @default(now())

  assignments  PropertyAssignment[]
  reservations Reservation[]
}

model PropertyAssignment {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  agentId    String
  agent      User     @relation(fields: [agentId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([propertyId, agentId])
  @@index([agentId])
}

model Reservation {
  id         String             @id @default(cuid())
  propertyId String
  property   Property           @relation(fields: [propertyId], references: [id])
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  rateType   RateType
  startAt    DateTime
  endAt      DateTime
  status     ReservationStatus  @default(pending)
  totalPrice Decimal            @db.Decimal(10, 2)
  createdAt  DateTime           @default(now())

  issueReports IssueReport[]

  @@index([userId])
  @@index([propertyId, startAt, endAt])
}

model IssueReport {
  id            String        @id @default(cuid())
  reservationId String
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  category      IssueCategory
  description   String
  photos        String[]      @default([])
  status        IssueStatus   @default(open)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([userId])
}

// Visit / booking requests submitted from the public property detail page
// ("Agendar Cita" for VENTA listings, "Reservar Espacio" for RENTA ones).
// The public catalog still lives in data/mockProperties.ts (not this DB),
// so we keep a denormalized snapshot of the property + assigned host
// instead of a foreign key. Once the real-estate catalog is migrated into
// Property, propertyId can become a proper relation.
model VisitRequest {
  id               String              @id @default(cuid())
  propertyId       String
  propertyTitle    String
  propertyLocation String
  type             VisitRequestType
  requesterName    String
  requesterPhone   String?
  requesterEmail   String?
  visitDate        DateTime
  visitTime        String
  message          String?
  agentName        String
  agentPhone       String
  status           VisitRequestStatus @default(pending)
  createdAt        DateTime           @default(now())

  @@index([propertyId])
  @@index([status])
}
