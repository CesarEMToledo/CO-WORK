// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// DATABASE_URL (definida en prisma.config.ts, ver ese archivo) debe ser la
// conexión Postgres de tu proyecto de Supabase (Project Settings -> Database
// -> Connection string). Usa el "Session pooler" (puerto 5432) o la conexión
// directa — el pooler en modo "Transaction" (puerto 6543) no es compatible
// con @prisma/adapter-pg.
datasource db {
  provider = "postgresql"
}

enum Role {
  client
  agent
  broker
  admin
}

enum AccessLevel {
  site
  global
}

enum UserStatus {
  active
  inactive
  away
}

enum PropertyType {
  office
  meeting_room
}

enum PropertyStatus {
  available
  maintenance
  inactive
}

enum RateType {
  hourly
  daily
  monthly
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
  completed
}

enum IssueCategory {
  maintenance
  cleaning
  internet
  other
}

enum IssueStatus {
  open
  in_progress
  resolved
}

enum VisitRequestType {
  visita
  reserva
}

enum VisitRequestStatus {
  pending
  contacted
  confirmed
  cancelled
}

enum ListingOperation {
  VENTA
  RENTA
}

/** Defaults to "disponible". Mirrors data/mockProperties.ts's PropertyStatus union. */
enum ListingStatus {
  disponible
  vendida
  rentada
  no_disponible
}

model Site {
  id         String     @id @default(cuid())
  name       String
  code       String     @unique
  users      User[]
  properties Property[]
  createdAt  DateTime   @default(now())
}

model User {
  id           String       @id @default(cuid())
  // Id del usuario en Supabase Auth (auth.users.id). La contraseña y el login
  // con Google los maneja Supabase; aquí solo guardamos el perfil de la app.
  authId       String       @unique
  name         String
  email        String       @unique
  phone        String?
  // URL pública del archivo en el bucket "avatars" de Supabase Storage.
  avatarUrl    String?
  role         Role         @default(client)
  accessLevel  AccessLevel?
  status       UserStatus   @default(active)
  siteId       String
  site         Site         @relation(fields: [siteId], references: [id])
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reservations       Reservation[]
  assignments        PropertyAssignment[]
  issueReports       IssueReport[]
  listings           Listing[]
  notifications      Notification[]
  featuredSlotsAdded FeaturedSlot[]

  @@index([role, siteId])
}

model Property {
  id          String         @id @default(cuid())
  siteId      String
  site        Site           @relation(fields: [siteId], references: [id])
  name        String
  type        PropertyType
  capacity    Int
  hourlyRate  Decimal        @db.Decimal(10, 2)
  dailyRate   Decimal        @db.Decimal(10, 2)
  monthlyRate Decimal        @db.Decimal(10, 2)
  status      PropertyStatus @default(available)
  createdAt   DateTime       @default(now())

  assignments  PropertyAssignment[]
  reservations Reservation[]
}

model PropertyAssignment {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  agentId    String
  agent      User     @relation(fields: [agentId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([propertyId, agentId])
  @@index([agentId])
}

model Reservation {
  id         String             @id @default(cuid())
  propertyId String
  property   Property           @relation(fields: [propertyId], references: [id])
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  rateType   RateType
  startAt    DateTime
  endAt      DateTime
  status     ReservationStatus  @default(pending)
  totalPrice Decimal            @db.Decimal(10, 2)
  createdAt  DateTime           @default(now())

  issueReports IssueReport[]

  @@index([userId])
  @@index([propertyId, startAt, endAt])
}

model IssueReport {
  id            String        @id @default(cuid())
  reservationId String
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  category      IssueCategory
  description   String
  photos        String[]      @default([])
  status        IssueStatus   @default(open)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([userId])
}

// Visit / booking requests submitted from the public property detail page
// ("Agendar Cita" for VENTA listings, "Reservar Espacio" for RENTA ones).
// The public catalog still lives in data/mockProperties.ts (not this DB),
// so we keep a denormalized snapshot of the property + assigned host
// instead of a foreign key. Once the real-estate catalog is migrated into
// Property, propertyId can become a proper relation.
model VisitRequest {
  id               String              @id @default(cuid())
  propertyId       String
  propertyTitle    String
  propertyLocation String
  type             VisitRequestType
  requesterName    String
  requesterPhone   String?
  requesterEmail   String?
  visitDate        DateTime
  visitTime        String
  message          String?
  agentName        String
  agentPhone       String
  status           VisitRequestStatus @default(pending)
  createdAt        DateTime           @default(now())

  @@index([propertyId])
  @@index([status])
}

// El catálogo de "publicar propiedad" (venta/renta de casas, terrenos, etc. —
// distinto del catálogo de espacios de coworking de arriba). Antes vivía solo
// en localStorage del navegador; ahora se guarda aquí, ligado al usuario que
// la publicó, para que "Mis propiedades" funcione desde cualquier dispositivo.
model Listing {
  id        String           @id @default(cuid())
  ownerId   String
  owner     User             @relation(fields: [ownerId], references: [id])
  title     String
  // Dirección: se guarda el texto ya armado para mostrar (location) y también
  // las partes sueltas para poder rellenar el formulario al editar.
  location  String
  // Nombre del estado tal cual aparece en data/mexico-geo.ts (ESTADOS) — con
  // default para que las propiedades publicadas antes de agregar este campo
  // (todas en San Luis Potosí) no se queden con un valor vacío.
  estado    String  @default("San Luis Potosí")
  municipio String
  localidad String?
  calle     String
  numero    String?
  colonia   String?
  // Coordenadas exactas del pin puesto a mano en el mapa (ver
  // components/LocationPicker.tsx) — nunca coordenadas re-geocodificadas del
  // texto de la dirección.
  lat         Decimal?         @db.Decimal(10, 7)
  lng         Decimal?         @db.Decimal(10, 7)
  price       String
  priceSuffix String?
  operation   ListingOperation
  category    String
  description String
  // Array de { icon, label }, ver PropertySpec en data/mockProperties.ts.
  specs     Json           @default("[]")
  imageUrl  String
  images    String[]       @default([])
  videoUrl  String?
  status    ListingStatus  @default(disponible)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  rentalTransactions RentalTransaction[]
  featuredSlots      FeaturedSlot[]

  @@index([ownerId])
  @@index([status])
}

// Un registro por cada renta ya cobrada de una propiedad en RENTA — para
// poder ver cuántas veces se ha rentado y las ganancias netas por mes. El
// desglose (comisión de Stripe, comisión de la plataforma, estimado de
// impuestos) se calcula y se GUARDA al momento de registrar la renta, para
// que si los porcentajes configurados cambian después, el historial ya
// registrado no se reescriba solo. Ver lib/earnings.ts para el cálculo y las
// notas sobre por qué son estimaciones, no cifras fiscales exactas.
model RentalTransaction {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  guestName String?
  notes     String?

  currency String @default("MXN")

  grossAmount        Decimal @db.Decimal(10, 2)
  stripeFeeAmount     Decimal @db.Decimal(10, 2)
  platformFeeAmount   Decimal @db.Decimal(10, 2)
  estimatedTaxAmount  Decimal @db.Decimal(10, 2)
  netAmount           Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([startDate])
}

// Cupo pagado (o regalado por un admin) en el carrusel de "Colecciones
// Destacadas" del inicio — máximo 6 cupos activos a la vez (ver
// lib/featured.ts), 7 días por cupo, $50 MXN/semana. El desglose de
// ingresos se calcula y GUARDA al crear el registro (mismo cálculo que
// RentalTransaction, ver lib/earnings.ts), para que cambios futuros a la
// configuración no reescriban el historial ya cobrado.
//
// isComplimentary = true cuando lo agregó un administrador gratis para una
// propiedad que no es suya — en ese caso el desglose de ingresos queda en
// cero (no hubo cobro real).
//
// Nota de alcance: por ahora esto NO cobra de verdad por Stripe — se crea
// como si el pago ya se hubiera hecho, para tener la funcionalidad y el
// reporte de ingresos listos antes de conectar el checkout real.
model FeaturedSlot {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  startDate DateTime @default(now())
  endDate   DateTime

  isComplimentary Boolean @default(false)

  grossAmount        Decimal @db.Decimal(10, 2)
  stripeFeeAmount    Decimal @db.Decimal(10, 2)
  platformFeeAmount  Decimal @db.Decimal(10, 2)
  estimatedTaxAmount Decimal @db.Decimal(10, 2)
  netAmount          Decimal @db.Decimal(10, 2)

  addedByUserId String
  addedBy       User   @relation(fields: [addedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([endDate])
}

enum NotificationType {
  // Alguien agendó una visita o pidió reservar una de tus propiedades
  // publicadas (viene de VisitRequest).
  interesado
  // Registraste una renta ya cobrada de una de tus propiedades.
  renta_registrada
  // Publicaste una propiedad nueva.
  propiedad_publicada
}

// Notificaciones de la campanita del navbar — hoy solo para dueños de
// propiedades publicadas (Listing), pero el modelo es genérico por si más
// adelante se usa para otra cosa. Se crean desde el servidor cada vez que
// pasa algo relevante (ver lib/notifications.ts); el cliente las consulta
// con polling desde lib/use-notifications.ts.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  // A dónde llevar al usuario si le da clic — por ahora siempre
  // /perfil/propiedades, pero se deja como campo por si distintos tipos de
  // notificación necesitan mandar a otro lado en el futuro.
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}
